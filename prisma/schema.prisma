generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// ENUMS
// =========================
enum UserType {
  applicant
  company
  admin
}

enum CompanySize {
  SIZE_1_10
  SIZE_10_50
  SIZE_50_100
  SIZE_100_PLUS
}

enum JobStatus {
  applied
  shortlisted
  hired
}

enum ResumeType {
  pdf
  json
}

// =========================
// USER MODEL
// =========================
model Auth {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  user_type  UserType @default(applicant)
  user_id    String?
  reset_hash String?
}

// =========================
// COMPANY MODEL
// =========================
model Company {
  id            String       @id @default(uuid())
  name          String
  email         String
  founding_year Int
  company_type  String
  contact_no    String
  website       String?
  linkedIn      String?
  twitter       String?
  address       String
  size          CompanySize?
  bio           String?

  jobs Job[]
}

// =========================
// APPLICANT MODEL
// =========================
model Applicant {
  id                   String  @id @default(uuid())
  name                 String
  mobile               String?
  email                String  @unique
  profile_pic          String?
  bio                  String?
  college_name         String?
  college_branch       String?
  college_joining_year String?

  resume      Resume[]
  appliedJobs AppliedJob[]
}

// =========================
// RESUME MODEL
// =========================
model Resume {
  id           String     @id @default(uuid())
  title        String
  type         ResumeType @default(pdf)
  url          String?
  json         Json?
  applicant    Applicant  @relation(fields: [applicant_id], references: [id])
  applicant_id String

  appliedJobs  AppliedJob[]
}

// =========================
// APPLIED JOB MODEL (replaces embedded type)
// =========================
model AppliedJob {
  id           String    @id @default(uuid())
  applicant    Applicant @relation(fields: [applicant_id], references: [id])
  applicant_id String

  job   Job    @relation(fields: [jobId], references: [id])
  jobId String

  resume              Resume @relation(fields: [applied_resume_id], references: [id])
  applied_resume_id   String

  status          JobStatus @default(applied)
  resume_url_used String?

}

// =========================
// JOB MODEL
// =========================
model Job {
  id         String  @id @default(uuid())
  company_id String
  company    Company @relation(fields: [company_id], references: [id])

  job_role        String
  description     String
  ctc             Float
  stipend         Float
  location        String
  skills_required Json

  applied_jobs AppliedJob[]
}
